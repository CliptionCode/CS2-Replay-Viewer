    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^22.20.1",
    "@types/three": "^0.178.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
